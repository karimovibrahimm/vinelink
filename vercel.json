{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "[^.]+\\.vinelink\\.xyz" }],
      "destination": "/api/profile"
    },
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "functions": {
    "api/profile.js": {
      "includeFiles": "dist/index.html"
    }
  }
}
